            { "id": "friend_feifei", "name": "气急败坏的妃妃", "icon": "😾", "hp": 34, "atk": 13, "def": 1, "spd": 95, "exp": 26, "gold": 18, "minStage": 1, "friend": true, "desc": "一口一个\u201c气死偶咧\u201d的暴躁郡主。一言不合就跺脚，但跺着跺着你就忍不住笑了出来。" }
