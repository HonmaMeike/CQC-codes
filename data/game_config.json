    "monsterStageScaling": {
        "_comment": "章节基础系数：第1-4章线性递增(1.0/1.4/1.8/2.2)，第5章起加速增长 Ch5=5/Ch6=10/Ch7=15...",
        "earlyStageMultiplierPerChapter": 0.4,
        "lateStageBase": 5,
        "lateStageThreshold": 5
    },

    "monsterLevelScaling": {
