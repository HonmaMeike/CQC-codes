        "hpGrowthPerLevel": 0.12,
        "atkGrowthPerLevel": 0.12,
        "defGrowthPerLevel": 0.10
    },

    "monsterBase": {
        "_comment": "怪物基础数值（会被 stageBaseMult × hpGrowth 等缩放）",
        "baseHP": 180,
        "baseATK": 2,
        "baseDEF": 3,
        "normalSpeed": 80,
        "eliteSpeed": 70,
        "bossSpeed": 60
    },

    "monsterElite": {
        "_comment": "精英怪倍率。HP×6, ATK×3, DEF×2.5",
        "hpMultiplier": 6,
        "atkMultiplier": 3,
        "defMultiplier": 2.5,
        "expBase": 60,
        "expGrowth": 0.15,
        "goldBase": 35,
        "goldGrowth": 0.15
    },

